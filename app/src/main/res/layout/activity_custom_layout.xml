<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CustomLayout">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/moodTextView"
            android:layout_width="match_parent"
            android:layout_height="86dp"
            android:layout_alignParentBottom="true"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/moodImageButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@+id/moodTextView"
            android:layout_alignEnd="@+id/moodTextView"
            android:layout_alignRight="@+id/moodTextView"
            android:layout_margin="20dp"
            android:background="@null"
            />

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>